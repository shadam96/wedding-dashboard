# Required: Neon Postgres connection string
# Get one free at https://neon.tech or via the Neon Vercel Integration
DATABASE_URL=

# Required: Password to access the dashboard
APP_PASSWORD=

# Optional: Override the auto-generated auth token (usually not needed)
# AUTH_TOKEN=

# Optional: Couple names shown in the UI (Hebrew defaults if not set)
NEXT_PUBLIC_GROOM_NAME=
NEXT_PUBLIC_BRIDE_NAME=
